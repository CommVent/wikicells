# ##############################################################################
# wikicells — environment configuration
#
# Copy to infra/.env and fill in. The .env file is gitignored.
#
# WARNING: never put comments on the same line as a variable — in some
# environments the trailing comment becomes part of the value.
# ##############################################################################


# ------------------------------------------------------------------------------
# Public hostnames
# ------------------------------------------------------------------------------
#
# WIKIBASE_PUBLIC_HOST — the canonical wiki hostname, e.g. yourdomain.example
#                        www.<host> and wiki.<host> redirect here automatically.
# WDQS_PUBLIC_HOST     — the SPARQL frontend, e.g. query.yourdomain.example
#
# All three names (bare, www, wiki) must resolve to the VPS public IP.
# Let's Encrypt issues certificates for all of them automatically on first boot.

WIKIBASE_PUBLIC_HOST=
WDQS_PUBLIC_HOST=


# ------------------------------------------------------------------------------
# Initial wiki admin
# ------------------------------------------------------------------------------
#
# Created on first boot. Set a strong MW_ADMIN_PASS.

MW_ADMIN_NAME=
MW_ADMIN_EMAIL=
MW_ADMIN_PASS=


# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
#
# Defaults are fine for a single-host deployment. Change DB_PASS before first
# boot — it's stored in the MariaDB volume.

DB_NAME=my_wiki
DB_USER=sqluser
DB_PASS=change-this-password


# ------------------------------------------------------------------------------
# Metadata callback (telemetry to wmde)
# ------------------------------------------------------------------------------
#
# Set to "false" to disable the optional anonymous deployment telemetry that
# the Wikibase image sends to Wikimedia Deutschland. We default to "true" to
# help upstream understand deployment patterns, but it's a values judgement.

METADATA_CALLBACK=true
